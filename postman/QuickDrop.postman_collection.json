          ] } }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": {
              "raw": "{{base_url}}/restaurants?search=&per_page=12",
              "host": ["{{base_url}}"], "path": ["restaurants"],
